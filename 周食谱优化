  function parseIngredients(str){ if(!str) return []; return [...new Set(str.split(/[、，]+/).map(s=>s.trim()).filter(s=>s))];}
  function getDiversity(individual){ let all=new Set(), cats={"谷、薯类":new Set(),"蔬菜、菌藻、水果类":new Set(),"畜、禽、鱼、蛋类及制品":new Set(),"奶、干豆、坚果、种子类及制品":new Set(),"盐油类":new Set()}; for(let m of ['breakfast','lunch','dinner']){ for(let it of individual[m]){ for(let ing of parseIngredients(it.food.ingredients)){ all.add(ing); let c=ingredientMap[ing]; if(c && cats[c]) cats[c].add(ing); } } } return {total:all.size, cats};}
  function computeAAS(items){ let totalP=0, aa={ile:0,leu:0,lys:0,saa:0,aaa:0,thr:0,trp:0,val:0}; for(let it of items){ let f=it.food, p=it.portion; totalP+=f.protein*p; for(let k in aa) aa[k]+=(f.amino[k]||0)*p; } if(totalP<0.01) return 0; let ref={ile:40,leu:70,lys:55,saa:35,aaa:60,thr:40,trp:10,val:50}, minSc=Infinity; for(let k in ref){ let mg=aa[k]/totalP, sc=mg/ref[k]; if(sc<minSc) minSc=sc; } return Math.min(100, minSc*100); }
  function sumNut(items){ let s={energy:0,protein:0,fat:0,carbs:0,ca:0,fe:0,zn:0,va:0,vb1:0,vb2:0,vc:0,cost:0}; for(let it of items){ let f=it.food,p=it.portion; s.energy+=f.energy*p; s.protein+=f.protein*p; s.fat+=f.fat*p; s.carbs+=f.carbs*p; s.ca+=f.ca*p; s.fe+=f.fe*p; s.zn+=f.zn*p; s.va+=f.va*p; s.vb1+=f.vb1*p; s.vb2+=f.vb2*p; s.vc+=f.vc*p; s.cost+=f.price*p; } return s; }
  function isValidDaily(individual, targetE){ let meals=['breakfast','lunch','dinner']; let totalE=0, pro=0,fat=0,carb=0, energies=[]; for(let m of meals){ let n=sumNut(individual[m]); energies.push(n.energy); totalE+=n.energy; pro+=n.protein; fat+=n.fat; carb+=n.carbs; } if(totalE<targetE*0.9||totalE>targetE*1.1) return false; let pctP=pro*4/totalE*100, pctF=fat*9/totalE*100, pctC=carb*4/totalE*100; if(pctP<10||pctP>15||pctF<20||pctF>30||pctC<50||pctC>65) return false; let bp=energies[0]/totalE*100, lp=energies[1]/totalE*100, dp=energies[2]/totalE*100; if(bp<25||bp>35||lp<30||lp>40||dp<30||dp>40) return false; let div=getDiversity(individual); if(div.total<12) return false; return true; }

  // 遗传算法生成每日候选 (根据目标类型)
  function getDailyCandidates(optimType, gender, numCandidates=6){
    const targetE = gender==='female'?1900:2400;
    const mealMap = { breakfast: foodsDB.filter(f=>f.meal==='breakfast'), lunch: foodsDB.filter(f=>f.meal==='lunch'), dinner: foodsDB.filter(f=>f.meal==='dinner') };
    function randomPortion(f){ if(!f.halfPort) return Math.random()<0.7?1:2; let r=Math.random(); return r<0.4?0.5:r<0.7?1:1.5; }
    function mutatePortion(f,cur){ if(!f.halfPort) return cur===1?2:1; let n=cur+(Math.random()-0.5)*0.8; return Math.min(1.5,Math.max(0.5,Math.round(n*2)/2)); }
    function randomInd(){ let ind={}; for(let m of ['breakfast','lunch','dinner']){ let cand=mealMap[m], num=Math.floor(Math.random()*3)+3, shuffled=[...cand]; for(let i=shuffled.length-1;i>0;i--){ let j=Math.floor(Math.random()*(i+1)); [shuffled[i],shuffled[j]]=[shuffled[j],shuffled[i]]; } let sel=shuffled.slice(0,Math.min(num,shuffled.length)); ind[m]=sel.map(f=>({food:f,portion:randomPortion(f)})); } return ind; }
    function fitness(ind){ if(!isValidDaily(ind,targetE)) return -1e9; let aas=Math.min(computeAAS(ind.breakfast),computeAAS(ind.lunch),computeAAS(ind.dinner)); let cost=sumNut(ind.breakfast).cost+sumNut(ind.lunch).cost+sumNut(ind.dinner).cost; if(optimType==='aas') return aas; if(optimType==='cost') return -cost; if(optimType==='balance') return 0.6*aas - 0.4*(cost/50)*100; return aas; }
    let pop=[], popSize=120; while(pop.length<popSize){ let ind=randomInd(); if(isValidDaily(ind,targetE)) pop.push(ind); }
    for(let g=0;g<80;g++){ pop.sort((a,b)=>fitness(b)-fitness(a)); let newPop=pop.slice(0,Math.floor(popSize/2)); while(newPop.length<popSize){ let p1=pop[Math.floor(Math.random()*popSize/2)], p2=pop[Math.floor(Math.random()*popSize/2)], child={}; for(let m of ['breakfast','lunch','dinner']){ let use=Math.random()<0.5?p1[m]:p2[m]; let mutated=use.map(item=>{ if(Math.random()<0.3) return {food:item.food,portion:mutatePortion(item.food,item.portion)}; return {...item}; }); if(Math.random()<0.15 && mealMap[m].length) mutated.push({food:mealMap[m][Math.floor(Math.random()*mealMap[m].length)],portion:randomPortion(mealMap[m][0])}); if(mutated.length<3) mutated.push({food:mealMap[m][Math.floor(Math.random()*mealMap[m].length)],portion:randomPortion(mealMap[m][0])}); child[m]=mutated; } if(isValidDaily(child,targetE)) newPop.push(child); else newPop.push(p1); } pop=newPop; }
    pop.sort((a,b)=>fitness(b)-fitness(a)); let unique=[], seen=new Set(); for(let ind of pop){ let key=JSON.stringify(ind); if(!seen.has(key) && unique.length<numCandidates){ seen.add(key); unique.push(ind); } } return unique;
  }

  // 周食谱组合选择（每日候选池，保证周总原料≥25）
  function selectWeeklyCombination(candidatesPerDay, targetType){
    let days=['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];
    let bestCombo=null, bestScore= (targetType==='cost')? Infinity : -Infinity;
    for(let i0=0;i0<candidatesPerDay[0].length;i0++){
      for(let i1=0;i1<candidatesPerDay[1].length;i1++){
        for(let i2=0;i2<candidatesPerDay[2].length;i2++){
          for(let i3=0;i3<candidatesPerDay[3].length;i3++){
            for(let i4=0;i4<candidatesPerDay[4].length;i4++){
              for(let i5=0;i5<candidatesPerDay[5].length;i5++){
                for(let i6=0;i6<candidatesPerDay[6].length;i6++){
                  let combo=[candidatesPerDay[0][i0],candidatesPerDay[1][i1],candidatesPerDay[2][i2],candidatesPerDay[3][i3],candidatesPerDay[4][i4],candidatesPerDay[5][i5],candidatesPerDay[6][i6]];
                  let allIngredients=new Set();
                  for(let dayInd of combo){ let div=getDiversity(dayInd); div.cats && Object.values(div.cats).forEach(s=>s.forEach(ing=>allIngredients.add(ing))); }
                  if(allIngredients.size>=25){
                    let weeklyAAS=0, totalCost=0;
                    for(let dayInd of combo){ let aas=Math.min(computeAAS(dayInd.breakfast),computeAAS(dayInd.lunch),computeAAS(dayInd.dinner)); weeklyAAS+=aas; totalCost+=sumNut(dayInd.breakfast).cost+sumNut(dayInd.lunch).cost+sumNut(dayInd.dinner).cost; }
                    let avgAAS=weeklyAAS/7;
                    if(targetType==='aas' && avgAAS>bestScore){ bestScore=avgAAS; bestCombo=combo; }
                    else if(targetType==='cost' && totalCost<bestScore){ bestScore=totalCost; bestCombo=combo; }
                    else if(targetType==='balance'){ let score=0.6*avgAAS - 0.4*(totalCost/50)*100; if(score>bestScore){ bestScore=score; bestCombo=combo; } }
                  }
                }
              }
            }
          }
        }
      }
    }
    return bestCombo;
  }

  async function generateWeeklyPlan(optimType, gender){
    let dailyCandidates=[];
    for(let i=0;i<7;i++){ let cand=getDailyCandidates(optimType,gender,5); dailyCandidates.push(cand); }
    let combo=selectWeeklyCombination(dailyCandidates,optimType);
    if(!combo){ for(let i=0;i<7;i++) dailyCandidates[i]=getDailyCandidates(optimType,gender,8); combo=selectWeeklyCombination(dailyCandidates,optimType); }
    if(!combo) throw new Error("无法找到满足周种类≥25的组合");
    return combo;
  }

  // 渲染：合并为一个食谱表格 + 完整综合评价表（含餐次比，每日原料数，微量实际摄入量）
  function renderWeekly(weeklyInds, gender, optimType){
    const days = ['周一', '周二', '周三', '周四', '周五', '周六', '周日'];
    // 统计数据累积
    let weekTotalNut = {energy:0, protein:0, fat:0, carbs:0, cost:0, ca:0, fe:0, zn:0, va:0, vb1:0, vb2:0, vc:0};
    let dailyIngCounts = [];
    let dailyAAS = [];
    let dailyBreakfastEnergy = [], dailyLunchEnergy = [], dailyDinnerEnergy = [];
    let allIngredientsSet = new Set();

    // 详细食谱表格生成
    let recipeRows = '';
    for(let idx=0; idx<weeklyInds.length; idx++){
      const ind = weeklyInds[idx];
      const div = getDiversity(ind);
      const ingCount = div.total;
      dailyIngCounts.push(ingCount);
      div.cats && Object.values(div.cats).forEach(s=>s.forEach(ing=>allIngredientsSet.add(ing)));
      // 当天AAS
      const dayAAS = Math.min(computeAAS(ind.breakfast), computeAAS(ind.lunch), computeAAS(ind.dinner));
      dailyAAS.push(dayAAS);
      // 三餐能量
      const breakfastNut = sumNut(ind.breakfast);
      const lunchNut = sumNut(ind.lunch);
      const dinnerNut = sumNut(ind.dinner);
      dailyBreakfastEnergy.push(breakfastNut.energy);
      dailyLunchEnergy.push(lunchNut.energy);
      dailyDinnerEnergy.push(dinnerNut.energy);

      // 累计周总量
      weekTotalNut.energy += breakfastNut.energy + lunchNut.energy + dinnerNut.energy;
      weekTotalNut.protein += breakfastNut.protein + lunchNut.protein + dinnerNut.protein;
      weekTotalNut.fat += breakfastNut.fat + lunchNut.fat + dinnerNut.fat;
      weekTotalNut.carbs += breakfastNut.carbs + lunchNut.carbs + dinnerNut.carbs;
      weekTotalNut.cost += breakfastNut.cost + lunchNut.cost + dinnerNut.cost;
      weekTotalNut.ca += breakfastNut.ca + lunchNut.ca + dinnerNut.ca;
      weekTotalNut.fe += breakfastNut.fe + lunchNut.fe + dinnerNut.fe;
      weekTotalNut.zn += breakfastNut.zn + lunchNut.zn + dinnerNut.zn;
      weekTotalNut.va += breakfastNut.va + lunchNut.va + dinnerNut.va;
      weekTotalNut.vb1 += breakfastNut.vb1 + lunchNut.vb1 + dinnerNut.vb1;
      weekTotalNut.vb2 += breakfastNut.vb2 + lunchNut.vb2 + dinnerNut.vb2;
      weekTotalNut.vc += breakfastNut.vc + lunchNut.vc + dinnerNut.vc;

      // 食谱行: 早餐/午餐/晚餐内容
      let breakfastHtml = '', lunchHtml = '', dinnerHtml = '';
      ind.breakfast.forEach(it => { breakfastHtml += `<div class="food-item">${it.food.name} (${it.portion}份)</div>`; });
      ind.lunch.forEach(it => { lunchHtml += `<div class="food-item">${it.food.name} (${it.portion}份)</div>`; });
      ind.dinner.forEach(it => { dinnerHtml += `<div class="food-item">${it.food.name} (${it.portion}份)</div>`; });

      recipeRows += `<tr>
        <td style="font-weight:600;">${days[idx]}</td>
        <td>${breakfastHtml || '—'}</td>
        <td>${lunchHtml || '—'}</td>
        <td>${dinnerHtml || '—'}</td>
        <td style="text-align:center;">${ingCount}</td>
        <td style="text-align:center;">${dayAAS.toFixed(1)}</td>
      </tr>`;
    }

    // 计算平均指标
    const avgEnergy = weekTotalNut.energy / 7;
    const pctP = (weekTotalNut.protein * 4 / weekTotalNut.energy) * 100;
    const pctF = (weekTotalNut.fat * 9 / weekTotalNut.energy) * 100;
    const pctC = (weekTotalNut.carbs * 4 / weekTotalNut.energy) * 100;
    const avgAAS = dailyAAS.reduce((a,b)=>a+b,0)/7;
    const avgDailyIng = dailyIngCounts.reduce((a,b)=>a+b,0)/7;
    const totalIng = allIngredientsSet.size;

    // 餐次比 (早/午/晚餐能量占比 平均)
    let avgBreakfastRatio = 0, avgLunchRatio = 0, avgDinnerRatio = 0;
    for(let i=0;i<7;i++){
      const dayTotal = dailyBreakfastEnergy[i] + dailyLunchEnergy[i] + dailyDinnerEnergy[i];
      if(dayTotal>0){
        avgBreakfastRatio += dailyBreakfastEnergy[i]/dayTotal*100;
        avgLunchRatio += dailyLunchEnergy[i]/dayTotal*100;
        avgDinnerRatio += dailyDinnerEnergy[i]/dayTotal*100;
      }
    }
    avgBreakfastRatio /= 7;
    avgLunchRatio /= 7;
    avgDinnerRatio /= 7;

    // RNI 参考 (性别)
    const rni = gender==='female' ?
            {ca:800, fe:20, zn:7.5, va:700, vb1:1.2, vb2:1.2, vc:100} :
            {ca:800, fe:12, zn:12.5, va:800, vb1:1.4, vb2:1.4, vc:100};

    // 日均摄入实际值
    const avgDaily = {
      ca: weekTotalNut.ca / 7,
      fe: weekTotalNut.fe / 7,
      zn: weekTotalNut.zn / 7,
      va: weekTotalNut.va / 7,
      vb1: weekTotalNut.vb1 / 7,
      vb2: weekTotalNut.vb2 / 7,
      vc: weekTotalNut.vc / 7
    };

    const microData = [
      {name:'钙 (Ca)', unit:'mg', actual:avgDaily.ca, rni:rni.ca, ratio: (avgDaily.ca/rni.ca)*100 },
      {name:'铁 (Fe)', unit:'mg', actual:avgDaily.fe, rni:rni.fe, ratio: (avgDaily.fe/rni.fe)*100 },
      {name:'锌 (Zn)', unit:'mg', actual:avgDaily.zn, rni:rni.zn, ratio: (avgDaily.zn/rni.zn)*100 },
      {name:'维生素A', unit:'μg RAE', actual:avgDaily.va, rni:rni.va, ratio: (avgDaily.va/rni.va)*100 },
      {name:'维生素B1', unit:'mg', actual:avgDaily.vb1, rni:rni.vb1, ratio: (avgDaily.vb1/rni.vb1)*100 },
      {name:'维生素B2', unit:'mg', actual:avgDaily.vb2, rni:rni.vb2, ratio: (avgDaily.vb2/rni.vb2)*100 },
      {name:'维生素C', unit:'mg', actual:avgDaily.vc, rni:rni.vc, ratio: (avgDaily.vc/rni.vc)*100 }
    ];

    // 合并食谱表格
    const recipeTableHtml = `
      <h3>📋 周食谱总览 (合并表) — 满足每日≥12种原料 · 周≥25种</h3>
      <table class="recipe-table">
        <thead>
          <tr><th>日期</th><th>🍳 早餐 (菜品+份量)</th><th>🍱 午餐 (菜品+份量)</th><th>🌙 晚餐 (菜品+份量)</th><th>📊 原料种类</th><th>🏅 AAS分值</th></tr>
        </thead>
        <tbody>${recipeRows}</tbody>
      </table>
    `;

    // 综合评价表 + 微量营养素详细表
    const evalHtml = `
      <div class="compare-row">
        <h3>📈 周食谱综合评价 (${gender==='female'?'女生 1900 kcal/日':'男生 2400 kcal/日'})</h3>
        <table class="summary-table">
          <thead><tr><th>指标</th><th>周总量 / 平均值</th><th>参考范围 / RNI</th><th>达标情况</th></tr></thead>
          <tbody>
            <tr><td>📆 平均能量 (kcal/d)</td><td>${avgEnergy.toFixed(0)}</td><td>${gender==='female'?1900:2400} ±10%</td><td>${Math.abs(avgEnergy-(gender==='female'?1900:2400))/(gender==='female'?1900:2400)*100<=10?'✅ 合格':'❌偏离'}</td></tr>
            <tr><td>🥩 蛋白质供能比 (%)</td><td>${pctP.toFixed(1)}%</td><td>10-15%</td><td>${pctP>=10 && pctP<=15?'✅':'❌'}</td></tr>
            <tr><td>🧈 脂肪供能比 (%)</td><td>${pctF.toFixed(1)}%</td><td>20-30%</td><td>${pctF>=20 && pctF<=30?'✅':'❌'}</td></tr>
            <tr><td>🍚 碳水供能比 (%)</td><td>${pctC.toFixed(1)}%</td><td>50-65%</td><td>${pctC>=50 && pctC<=65?'✅':'❌'}</td></tr>
            <tr><td>🍳 早餐餐次比 (%)</td><td>${avgBreakfastRatio.toFixed(1)}%</td><td>25-35%</td><td>${avgBreakfastRatio>=25 && avgBreakfastRatio<=35?'✅':'❌'}</td></tr>
            <tr><td>🍱 午餐餐次比 (%)</td><td>${avgLunchRatio.toFixed(1)}%</td><td>30-40%</td><td>${avgLunchRatio>=30 && avgLunchRatio<=40?'✅':'❌'}</td></tr>
            <tr><td>🌙 晚餐餐次比 (%)</td><td>${avgDinnerRatio.toFixed(1)}%</td><td>30-40%</td><td>${avgDinnerRatio>=30 && avgDinnerRatio<=40?'✅':'❌'}</td></tr>
            <tr><td>⭐ 平均氨基酸评分(AAS)</td><td>${avgAAS.toFixed(1)}分</td><td>≥80较优</td><td>${avgAAS>=80?'✅优秀':(avgAAS>=60?'⚠️一般':'❌较低')}</td></tr>
            <tr><td>💰 周总费用 (元)</td><td>${weekTotalNut.cost.toFixed(2)} 元</td><td colspan="2">🎯 优化目标: ${optimType==='aas'?'AAS最高':(optimType==='cost'?'成本最低':'兼顾AAS/成本')}</td></tr>
            <tr><td>🌿 每日原料种类数 (均值)</td><td>${avgDailyIng.toFixed(1)} 种/日</td><td>≥12种/日</td><td>${avgDailyIng>=12?'✅满足':'❌不足'}</td></tr>
            <tr><td>📦 周原料总种类数</td><td>${totalIng} 种</td><td>≥25种</td><td>${totalIng>=25?'✅满足':'❌不足'}</td></tr>
          </tbody>
        </table>

        <h4>🥛 微量营养素日均摄入量及达标率 (周平均)</h4>
        <table class="summary-table micro-table">
          <thead><tr><th>营养素</th><th>日均实际摄入量</th><th>RNI (参考)</th><th>达标率 (%)</th><th>评价</th></tr></thead>
          <tbody>
            ${microData.map(m => `<tr>
              <td>${m.name}</td>
              <td>${m.actual.toFixed(1)} ${m.unit}</td>
              <td>${m.rni} ${m.unit}</td>
              <td>${m.ratio.toFixed(0)}%</td>
              <td>${m.ratio>=80?'✅充足':(m.ratio>=60?'⚠️注意':'❌不足')}</td>
            </tr>`).join('')}
          </tbody>
        </table>
        <div class="badge">✨ 优化驱动: ${optimType==='aas'?'氨基酸评分最大化':(optimType==='cost'?'费用最经济':'兼顾AAS与成本')} | 每日原料≥12种 ✔️ 周总原料≥25种 ✔️ 硬约束全部满足</div>
      </div>
    `;

    return recipeTableHtml + evalHtml;
  }


  let currentGender='female', currentObj='aas';
  document.getElementById('gender-female').onclick=()=>{ currentGender='female'; document.getElementById('gender-female').classList.add('active'); document.getElementById('gender-male').classList.remove('active'); generateAndRender(); };
  document.getElementById('gender-male').onclick=()=>{ currentGender='male'; document.getElementById('gender-male').classList.add('active'); document.getElementById('gender-female').classList.remove('active'); generateAndRender(); };
  document.getElementById('obj-aas').onclick=()=>{ currentObj='aas'; setActiveObj('obj-aas'); generateAndRender(); };
  document.getElementById('obj-cost').onclick=()=>{ currentObj='cost'; setActiveObj('obj-cost'); generateAndRender(); };
  document.getElementById('obj-balance').onclick=()=>{ currentObj='balance'; setActiveObj('obj-balance'); generateAndRender(); };
  function setActiveObj(activeId){ ['obj-aas','obj-cost','obj-balance'].forEach(id=>{ let btn=document.getElementById(id); if(id===activeId) btn.classList.add('active'); else btn.classList.remove('active'); }); }
  async function generateAndRender(){
    let resultDiv=document.getElementById('weeklyResult');
    resultDiv.innerHTML='<div class="loading">⏳ 遗传算法优化周食谱中 (满足每日≥12种，周≥25种，硬约束严格) ...</div>';
    setTimeout(async ()=>{
      try{
        let weekly=await generateWeeklyPlan(currentObj, currentGender);
        let html=renderWeekly(weekly, currentGender, currentObj);
        resultDiv.innerHTML=html;
      }catch(e){ resultDiv.innerHTML=`<div class="loading">❌ 优化失败，请重试: ${e.message}</div>`; }
    },50);
  }
  generateAndRender();
</script>
</body>
</html>

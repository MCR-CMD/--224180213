  function parseIngredients(str) { if(!str) return []; return [...new Set(str.split(/[、，]+/).map(s=>s.trim()).filter(s=>s))]; }
  function getDiversityByIngredients(ind) {
    let all=new Set(), cats={"谷、薯类":new Set(),"蔬菜、菌藻、水果类":new Set(),"畜、禽、鱼、蛋类及制品":new Set(),"奶、干豆、坚果、种子类及制品":new Set(),"盐油类":new Set()};
    for(let m of ['breakfast','lunch','dinner']) for(let it of ind[m]) for(let ing of parseIngredients(it.food.ingredients)) { all.add(ing); let c=ingredientCategoryMap[ing]; if(c&&cats[c]) cats[c].add(ing); }
    let cnt={}; for(let k of Object.keys(cats)) cnt[k]=cats[k].size;
    return { totalIngredients: all.size, catCounts: cnt };
  }
  const refAA={ ile:40, leu:70, lys:55, saa:35, aaa:60, thr:40, trp:10, val:50 };
  function computeMealAAS(items){ let tp=0,taa={ile:0,leu:0,lys:0,saa:0,aaa:0,thr:0,trp:0,val:0}; for(let it of items){ let f=it.food,p=it.portion; tp+=f.protein*p; for(let aa in taa) taa[aa]+=(f.amino[aa]||0)*p; } if(tp<0.01) return 0; let min=Infinity; for(let aa in refAA){ let mg=taa[aa]/tp, sc=mg/refAA[aa]; if(sc<min) min=sc; } return Math.min(1,min)*100; }
  function sumNutrition(items){ let s={energy:0,protein:0,fat:0,carbs:0,fiber:0,va:0,vb1:0,vb2:0,vc:0,ca:0,fe:0,zn:0,cost:0}; for(let it of items){ let f=it.food,p=it.portion; s.energy+=f.energy*p; s.protein+=f.protein*p; s.fat+=f.fat*p; s.carbs+=f.carbs*p; s.fiber+=f.fiber*p; s.va+=f.va*p; s.vb1+=f.vb1*p; s.vb2+=f.vb2*p; s.vc+=f.vc*p; s.ca+=f.ca*p; s.fe+=f.fe*p; s.zn+=f.zn*p; s.cost+=f.price*p; } return s; }
  function isIndividualValid(ind,target){ let meals=['breakfast','lunch','dinner']; let totalE=0,totalP=0,totalF=0,totalC=0,mealE=[]; for(let m of meals){ let nut=sumNutrition(ind[m]); mealE.push(nut.energy); totalE+=nut.energy; totalP+=nut.protein; totalF+=nut.fat; totalC+=nut.carbs; } if(totalE<target*0.9||totalE>target*1.1) return false; let pctP=(totalP*4/totalE)*100, pctF=(totalF*9/totalE)*100, pctC=(totalC*4/totalE)*100; if(pctP<10||pctP>15||pctF<20||pctF>30||pctC<50||pctC>65) return false; let br=mealE[0]/totalE*100, lu=mealE[1]/totalE*100, di=mealE[2]/totalE*100; return (br>=25&&br<=35&&lu>=30&&lu<=40&&di>=30&&di<=40); }
  function diversityBonus(ind){ let {totalIngredients,catCounts}=getDiversityByIngredients(ind); let missing=Object.keys(catCounts).filter(c=>catCounts[c]===0); return (totalIngredients>=12?5:-10)-missing.length*8; }
  function fitnessAAS(ind,target){ if(!isIndividualValid(ind,target)) return -1e9; let minAAS=Math.min(...['breakfast','lunch','dinner'].map(m=>computeMealAAS(ind[m]))); let totalNut={ca:0,fe:0,zn:0,va:0,vb1:0,vb2:0,vc:0}; for(let m of ['breakfast','lunch','dinner']){ let n=sumNutrition(ind[m]); for(let k in totalNut) totalNut[k]+=n[k]; } let rni=target===1900?{ca:800,fe:20,zn:7.5,va:700,vb1:1.2,vb2:1.2,vc:100}:{ca:800,fe:12,zn:12.5,va:800,vb1:1.4,vb2:1.4,vc:100}; let micro=0; for(let k of ['ca','fe','zn','va','vb1','vb2','vc']) micro+=Math.min(1,totalNut[k]/rni[k]); micro/=7; return minAAS*10 + micro*5 + diversityBonus(ind); }
  function fitnessCost(ind,target){ if(!isIndividualValid(ind,target)) return -1e9; let cost=0; for(let m of ['breakfast','lunch','dinner']) cost+=sumNutrition(ind[m]).cost; return -cost + diversityBonus(ind); }
  function fitnessCombined(ind,target){ if(!isIndividualValid(ind,target)) return -1e9; let minAAS=Math.min(...['breakfast','lunch','dinner'].map(m=>computeMealAAS(ind[m]))); let cost=0; for(let m of ['breakfast','lunch','dinner']) cost+=sumNutrition(ind[m]).cost; let normCost=Math.min(1,cost/50); return 0.6*minAAS - 0.4*normCost*100 + diversityBonus(ind); }
  function getRandomPortion(f){ if(!f.halfPort) return Math.random()<0.7?1:2; let r=Math.random(); if(r<0.4) return 0.5; if(r<0.7) return 1; return 1.5; }
  function mutatePortion(f,cur){ if(!f.halfPort) return cur===1?2:1; let n=cur+(Math.random()-0.5)*0.8; n=Math.min(1.5,Math.max(0.5,n)); return Math.round(n*2)/2; }
  function randomIndividual(map){ let ind={}; for(let meal of ['breakfast','lunch','dinner']){ let cand=map[meal]; let num=Math.floor(Math.random()*3)+3; let shuffled=[...cand]; for(let i=shuffled.length-1;i>0;i--){let j=Math.floor(Math.random()*(i+1));[shuffled[i],shuffled[j]]=[shuffled[j],shuffled[i]];} let sel=shuffled.slice(0,Math.min(num,shuffled.length)); ind[meal]=sel.map(f=>({food:f,portion:getRandomPortion(f)})); } return ind; }
  function optimize(target,mealMap,fitnessFunc,pop=150,gen=120){ let popu=[]; while(popu.length<pop){ let ind=randomIndividual(mealMap); if(isIndividualValid(ind,target)) popu.push(ind); } for(let g=0;g<gen;g++){ popu.sort((a,b)=>fitnessFunc(b,target)-fitnessFunc(a,target)); let newPop=popu.slice(0,Math.floor(pop/2)); while(newPop.length<pop){ let p1=popu[Math.floor(Math.random()*pop/2)], p2=popu[Math.floor(Math.random()*pop/2)]; let child={}; for(let meal of ['breakfast','lunch','dinner']){ let use=Math.random()<0.5?p1[meal]:p2[meal]; let mut=use.map(it=>{ if(Math.random()<0.3) return {food:it.food,portion:mutatePortion(it.food,it.portion)}; return {...it}; }); if(Math.random()<0.15&&mealMap[meal].length) mut.push({food:mealMap[meal][Math.floor(Math.random()*mealMap[meal].length)],portion:getRandomPortion(mealMap[meal][0])}); if(mut.length<3) mut.push({food:mealMap[meal][Math.floor(Math.random()*mealMap[meal].length)],portion:getRandomPortion(mealMap[meal][0])}); child[meal]=mut; } if(isIndividualValid(child,target)) newPop.push(child); else newPop.push(p1); } popu=newPop; } popu.sort((a,b)=>fitnessFunc(b,target)-fitnessFunc(a,target)); return popu[0]; }
  const mealMapFull={breakfast:foodsDB.filter(f=>f.meal==='breakfast'),lunch:foodsDB.filter(f=>f.meal==='lunch'),dinner:foodsDB.filter(f=>f.meal==='dinner')};
  let currentGender='female', currentMode='combined';
  document.getElementById('mode-aas').addEventListener('click',()=>{ currentMode='aas'; document.querySelectorAll('.mode-btn').forEach(btn=>btn.classList.remove('active')); document.getElementById('mode-aas').classList.add('active'); document.getElementById('weightHint').innerText='当前模式：仅最大化氨基酸评分'; });
  document.getElementById('mode-cost').addEventListener('click',()=>{ currentMode='cost'; document.querySelectorAll('.mode-btn').forEach(btn=>btn.classList.remove('active')); document.getElementById('mode-cost').classList.add('active'); document.getElementById('weightHint').innerText='当前模式：仅最小化成本'; });
  document.getElementById('mode-combined').addEventListener('click',()=>{ currentMode='combined'; document.querySelectorAll('.mode-btn').forEach(btn=>btn.classList.remove('active')); document.getElementById('mode-combined').classList.add('active'); document.getElementById('weightHint').innerText='当前权重：氨基酸 60% | 成本 40%'; });
  document.getElementById('btn-female').addEventListener('click',()=>{ currentGender='female'; document.getElementById('btn-female').classList.add('active'); document.getElementById('btn-male').classList.remove('active'); });
  document.getElementById('btn-male').addEventListener('click',()=>{ currentGender='male'; document.getElementById('btn-male').classList.add('active'); document.getElementById('btn-female').classList.remove('active'); });
  function renderDiet(ind,target,gender,totalCost){ let meals=['breakfast','lunch','dinner'], names={breakfast:'早餐',lunch:'午餐',dinner:'晚餐'}; let html=`<div class="result-grid">`; for(let m of meals){ let items=ind[m], nut=sumNutrition(items), aas=computeMealAAS(items); html+=`<div class="meal-card"><div class="meal-title">🍽️ ${names[m]}  (成本: ${nut.cost.toFixed(2)}元 | AAS: ${aas.toFixed(1)}分)</div>`; for(let it of items){ let half=!it.food.halfPort?'<span class="half-restrict">🔒整份</span>':''; html+=`<div class="food-item"><span class="food-name">${it.food.name}</span><span class="food-detail">${it.portion}份 ${half}<br><span class="ingredients">📌 主要成分: ${it.food.ingredients}</span></span></div>`; } html+=`<div style="margin-top:12px; font-size:0.8rem;">🔹 能量:${nut.energy.toFixed(0)}kcal &nbsp; 蛋白质:${nut.protein.toFixed(1)}g</div></div>`; } html+=`</div>`; let totalE=0,totalP=0,totalF=0,totalC=0,totalFib=0,mealE={}; for(let m of meals){ let nut=sumNutrition(ind[m]); mealE[m]=nut.energy; totalE+=nut.energy; totalP+=nut.protein; totalF+=nut.fat; totalC+=nut.carbs; totalFib+=nut.fiber; } let pctP=(totalP*4/totalE)*100,pctF=(totalF*9/totalE)*100,pctC=(totalC*4/totalE)*100; let br=mealE.breakfast/totalE*100,lu=mealE.lunch/totalE*100,di=mealE.dinner/totalE*100; let {totalIngredients,catCounts}=getDiversityByIngredients(ind); let catRows=''; for(let [cat,label] of Object.entries({"谷、薯类":"🌾 谷、薯类","蔬菜、菌藻、水果类":"🥬 蔬菜菌藻水果","畜、禽、鱼、蛋类及制品":"🐟 畜禽鱼蛋","奶、干豆、坚果、种子类及制品":"🥛 奶豆坚果","盐油类":"🧂 盐油类"})) catRows+=`<tr><td style="text-align:left;">${label}</td><td>${catCounts[cat]||0}</td></tr>`; let missing=Object.keys(catCounts).filter(c=>catCounts[c]===0);
    // 非产能营养素 (包含膳食纤维)
    let dailyMicro={ca:0,fe:0,zn:0,va:0,vb1:0,vb2:0,vc:0,fiber:0}; for(let m of meals){ let n=sumNutrition(ind[m]); dailyMicro.ca+=n.ca; dailyMicro.fe+=n.fe; dailyMicro.zn+=n.zn; dailyMicro.va+=n.va; dailyMicro.vb1+=n.vb1; dailyMicro.vb2+=n.vb2; dailyMicro.vc+=n.vc; dailyMicro.fiber+=n.fiber; }
    let rniBase=target===1900?{ca:800,fe:20,zn:7.5,va:700,vb1:1.2,vb2:1.2,vc:100}:{ca:800,fe:12,zn:12.5,va:800,vb1:1.4,vb2:1.4,vc:100};
    const nutrientOrder=[
      {key:'ca',name:'钙(mg)',rni:rniBase.ca},{key:'fe',name:'铁(mg)',rni:rniBase.fe},{key:'zn',name:'锌(mg)',rni:rniBase.zn},
      {key:'va',name:'VA(μg)',rni:rniBase.va},{key:'vb1',name:'VB1(mg)',rni:rniBase.vb1},{key:'vb2',name:'VB2(mg)',rni:rniBase.vb2},
      {key:'vc',name:'VC(mg)',rni:rniBase.vc},{key:'fiber',name:'膳食纤维(g)',rni:25}
    ];
    let microRows=`<tr><th>指标</th>${nutrientOrder.map(n=>`<th>${n.name}</th>`).join('')}</tr>
                   <tr><td style="text-align:left;"><strong>摄入量</strong></td>${nutrientOrder.map(n=>`<td>${(n.key==='fiber'?dailyMicro.fiber.toFixed(1):dailyMicro[n.key].toFixed(n.key==='vb1'||n.key==='vb2'?2:0))}</td>`).join('')}</tr>
                   <tr><td style="text-align:left;"><strong>RNI</strong></td>${nutrientOrder.map(n=>`<td>${n.rni}</td>`).join('')}</tr>
                   <tr><td style="text-align:left;"><strong>占RNI(%)</strong></td>${nutrientOrder.map(n=>{ let val=n.key==='fiber'?dailyMicro.fiber:dailyMicro[n.key]; return `<td>${((val/n.rni)*100).toFixed(0)}%</td>`; }).join('')}</tr>`;
    html+=`<div class="analysis-section"><div class="analysis-title">💰 总成本: ${totalCost.toFixed(2)} 元 &nbsp; | 🧬 最低氨基酸评分: ${Math.min(computeMealAAS(ind.breakfast),computeMealAAS(ind.lunch),computeMealAAS(ind.dinner)).toFixed(1)}分</div><div class="analysis-title">📋 食物结构分析(主要成分原料)</div><table class="nutri-table"><thead><tr><th>五大类</th><th>种类数</th></tr></thead><tbody>${catRows}</tbody></table><div>✅ 原料总种类: ${totalIngredients} 种 (≥12) &nbsp; 五大类全覆盖: ${missing.length===0?'✔️ 是':'❌ 缺失:'+missing.join(',')}</div><div class="analysis-title">📊 主要营养素</div><table class="nutri-table"><tr><th>项目</th><th>能量(kcal)</th><th>蛋白质(g)</th><th>脂肪(g)</th><th>碳水(g)</th><th>膳食纤维(g)</th></tr><tr><td>全日合计</td><td>${totalE.toFixed(0)}</td><td>${totalP.toFixed(1)}</td><td>${totalF.toFixed(1)}</td><td>${totalC.toFixed(1)}</td><td>${totalFib.toFixed(1)}</td></tr></table><div class="analysis-title">⏲️ 餐次比</div><table class="nutri-table"><tr><th>餐次</th><th>能量(kcal)</th><th>占比(%)</th><th>参考</th></tr><tr><td>早餐</td><td>${mealE.breakfast.toFixed(0)}</td><td>${br.toFixed(1)}%</td><td>25-35%</td></tr><tr><td>午餐</td><td>${mealE.lunch.toFixed(0)}</td><td>${lu.toFixed(1)}%</td><td>30-40%</td></tr><tr><td>晚餐</td><td>${mealE.dinner.toFixed(0)}</td><td>${di.toFixed(1)}%</td><td>30-40%</td></tr></table><div class="analysis-title">⚖️ 宏量供能比</div><table class="nutri-table"><tr><th>营养素</th><th>摄入(g)</th><th>供能(kcal)</th><th>占比(%)</th><th>参考</th></tr><tr><td>蛋白质</td><td>${totalP.toFixed(1)}</td><td>${(totalP*4).toFixed(0)}</td><td>${pctP.toFixed(1)}%</td><td>10-15%</td></tr><tr><td>脂肪</td><td>${totalF.toFixed(1)}</td><td>${(totalF*9).toFixed(0)}</td><td>${pctF.toFixed(1)}%</td><td>20-30%</td></tr><tr><td>碳水</td><td>${totalC.toFixed(1)}</td><td>${(totalC*4).toFixed(0)}</td><td>${pctC.toFixed(1)}%</td><td>50-65%</td></tr></table><div class="analysis-title">🧬 每餐AAS评分</div><table class="nutri-table"><tr><th>餐次</th><th>AAS(分)</th></tr><tr><td>早餐</td><td>${computeMealAAS(ind.breakfast).toFixed(1)}</td></tr><tr><td>午餐</td><td>${computeMealAAS(ind.lunch).toFixed(1)}</td></tr><tr><td>晚餐</td><td>${computeMealAAS(ind.dinner).toFixed(1)}</td></tr></table><div class="analysis-title">🥛 (6) 非产能主要营养素评价 (${gender==='female'?'女生RNI':'男生RNI'} ＋ 膳食纤维25g)</div><table class="nutri-table">${microRows}</table></div>`; return html; }
  document.getElementById('optimizeBtn').addEventListener('click',()=>{ let target=currentGender==='female'?1900:2400; let fitFunc=currentMode==='aas'?fitnessAAS:(currentMode==='cost'?fitnessCost:fitnessCombined); document.getElementById('resultArea').innerHTML='<div class="loading">⚙️ 遗传算法优化中，模式：'+ (currentMode==='aas'?'氨基酸最大化':(currentMode==='cost'?'成本最小化':'综合优化6:4')) +'...</div>'; setTimeout(()=>{ let best=optimize(target,mealMapFull,fitFunc,150,120); let totalCost=0; for(let m of ['breakfast','lunch','dinner']) totalCost+=sumNutrition(best[m]).cost; let htmlRes=renderDiet(best,target,currentGender,totalCost); document.getElementById('resultArea').innerHTML=htmlRes; },30); });
  window.addEventListener('load',()=>{ let best=optimize(1900,mealMapFull,fitnessCombined,150,120); let cost=0; for(let m of ['breakfast','lunch','dinner']) cost+=sumNutrition(best[m]).cost; document.getElementById('resultArea').innerHTML=renderDiet(best,1900,'female',cost); });
</script>
